# ==============================================
# AGENTE WHATSAPP + CLAUDE — Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env com valores reais para o Git!

# ----------------------------------------------
# OBRIGATÓRIO — Chave da API Anthropic
# Obtenha em: https://console.anthropic.com/
# ----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-COLOQUE_SUA_CHAVE_AQUI

# ----------------------------------------------
# OPCIONAL — Modelo Claude a usar
# Opções: claude-sonnet-4-5 | claude-sonnet-4-6 | claude-opus-4-7 | claude-haiku-4-5-20251001
# ----------------------------------------------
CLAUDE_MODEL=claude-sonnet-4-5

# ----------------------------------------------
# OPCIONAL — Caminho do banco de dados SQLite
# No EasyPanel/Docker, aponte para dentro do volume montado
# ----------------------------------------------
DB_PATH=/app/data/sessions.db

# ----------------------------------------------
# OPCIONAL — Porta HTTP (uso futuro)
# ----------------------------------------------
PORT=3000

# ----------------------------------------------
# OPCIONAL — Integração ClickUp
# CLICKUP_API_KEY: Configurações → Apps → API Token
# CLICKUP_TEAM_ID: ID do workspace (aparece na URL do ClickUp)
# Se não configurado, o bot funciona normalmente sem ClickUp
# ----------------------------------------------
CLICKUP_API_KEY=pk_COLOQUE_SEU_TOKEN_AQUI
CLICKUP_TEAM_ID=SEU_TEAM_ID_AQUI
